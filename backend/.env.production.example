# ResearchMind AI - Production Backend Environment Variables
APP_ENV=production
DEBUG=false
PORT=80
HOST=0.0.0.0

# Persistent Volumes Storage Paths (Render Disk Mount)
DATABASE_URL=sqlite:////var/data/researchmind.db
CHROMA_PERSIST_DIR=/var/data/chromadb_data
UPLOAD_DIR=/var/data/uploaded_papers

# OpenAI Configuration
OPENAI_API_KEY=your_production_openai_api_key_here

# Embedding Engine Choice (local / openai)
EMBEDDING_ENGINE=local

# CORS Configuration (Commas separate allowed origins)
ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app,http://localhost:5173
