# ResearchMind AI Environment Configuration
# Copy this file to .env and fill in the values.

# General Configuration
APP_NAME="ResearchMind AI"
APP_ENV=development
DEBUG=True
PORT=8000
HOST=0.0.0.0

# Database Configuration
# For development, we use local SQLite. For production, specify PostgreSQL URL.
DATABASE_URL=sqlite:///./researchmind.db

# Vector Store Configuration
# Path to ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chromadb_data

# LLM & Embedding Settings
# OpenAI API Key for LangGraph Agent nodes
OPENAI_API_KEY=

# Embedding Engine Choice: 'local' (Sentence Transformers) or 'openai'
EMBEDDING_ENGINE=local
# If using 'openai', specify OpenAI embedding model (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local Embedding Model name (downloaded/cached by SentenceTransformers)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage Configuration
# Folder where uploaded PDFs will be saved
UPLOAD_DIR=./uploaded_papers
MAX_UPLOAD_SIZE_MB=10

# CORS Configuration
# Allowed origins for frontend access (separated by commas)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
