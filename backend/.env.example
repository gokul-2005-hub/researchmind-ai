# ResearchMind AI Environment Configuration
# Copy this file to .env and fill in the values.

# General Configuration
APP_NAME="ResearchMind AI"
APP_ENV=development
DEBUG=True
PORT=8000
HOST=0.0.0.0

# Database Configuration
# For development, we use local SQLite. For production, specify PostgreSQL URL.
DATABASE_URL=sqlite:///./researchmind.db

# Vector Store Configuration
# Path to ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chromadb_data

# LLM & Embedding Settings
# OpenAI API Key for LangGraph Agent nodes (single fallback key)
OPENAI_API_KEY=

# 1. Models to use
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=openrouter/free

# 2. Provider Fallback Orders (Which provider should the agent try first?)
FALLBACK_ORDER=gemini,groq,openrouter

# 3. Master Keys (Paste all your keys here, comma-separated)
ALL_GEMINI_KEYS=
ALL_GROQ_KEYS=
ALL_OPENROUTER_KEYS=

# Embedding Engine Choice: 'local' (Sentence Transformers) or 'openai'
EMBEDDING_ENGINE=local
# If using 'openai', specify OpenAI embedding model (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local Embedding Model name (downloaded/cached by SentenceTransformers)
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage Configuration
# Folder where uploaded PDFs will be saved
UPLOAD_DIR=./uploaded_papers
MAX_UPLOAD_SIZE_MB=10

# CORS Configuration
# Allowed origins for frontend access (separated by commas)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
